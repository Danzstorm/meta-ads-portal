# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and will NOT be committed to the repository.

# Your Meta (Facebook) App ID — found at developers.facebook.com
NEXT_PUBLIC_META_APP_ID=YOUR_APP_ID_HERE

# Optional: hardcode an access token for local development only.
# Leave empty to use the login flow in the app.
NEXT_PUBLIC_META_ACCESS_TOKEN=
